# CryptoClaw 环境变量配置
# 复制此文件为 .env 并填写实际值: cp .env.example .env

# ============================================
# 基础配置
# ============================================

# 时区
TZ=Asia/Shanghai

# 宿主机端口 (默认 3000)
HOST_PORT=3000

# ============================================
# Telegram Bot 配置 (必需)
# ============================================

# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# LLM 配置 (必需)
# ============================================

# LLM 提供商: openai, anthropic, deepseek, custom
LLM_PROVIDER=openai

# LLM API Key
LLM_API_KEY=your_llm_api_key_here

# LLM 模型
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229
# DeepSeek: deepseek-chat, deepseek-coder
LLM_MODEL=gpt-4

# ============================================
# 自定义 LLM 提供商配置 (LLM_PROVIDER=custom 时使用)
# ============================================

# API 基础 URL (例如: http://localhost:11434/v1 for Ollama)
LLM_BASE_URL=

# API 版本 (某些提供商需要，如 Azure OpenAI)
LLM_API_VERSION=

# ============================================
# 交易所 API 配置 (可选，用于实盘交易)
# ============================================

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ============================================
# Freqtrade 配置 (可选)
# ============================================

# Freqtrade REST API / JSON-RPC URL
# 默认: http://localhost:8080
FREQTRADE_URL=http://localhost:8080

# Freqtrade JSON-RPC 认证 (可选，如果 Freqtrade 配置了密码保护)
FREQTRADE_USERNAME=
FREQTRADE_PASSWORD=
